class Solution {
public:
    bool areSimilar(vector<vector<int>>& mat, int k) {
        int n=mat.size(), m=mat[0].size();
        k%=m;
        vector<vector<int>>mt(n,vector<int>(m));
        mt=mat;
        if(k==0) return true;
        for(int i=0; i<k; i++){
            for(int r=0; r<n; r++){
                if(r%2==0){
                    int l=mt[r][0];
                    for(int j=0; j<m-1; j++){
                        mt[r][j]=mt[r][j+1];
                    }
                    mt[r][m-1]=l;
                }else{
                    int ri=mt[r][m-1];
                    for(int j=m-1; j>0; j--){
                        mt[r][j]=mt[r][j-1];
                    }
                    mt[r][0]=ri;
                }
            }
        }
        int f=0;
        for(int i=0; i<n; i++){
            for(int j=0; j<m; j++){
                if(mat[i][j]!=mt[i][j]){
                    f=1;
                    break;
                }
            }
            if(f==1) break;
        }
        return (f==1) ? false:true;
    }
};
