class Solution {
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
        vector<int>m;
        for(int i=0; i<nums1.size(); i++){
            m.push_back(nums1[i]);
        }
        for(int i=0; i<nums2.size(); i++){
            m.push_back(nums2[i]);
        }
        sort(m.begin(),m.end());
        if(m.size()%2==1) return float(m[m.size()/2]);
        else return float((m[(m.size()-1)/2]+m[(m.size())/2])/2.0);
    }
};
