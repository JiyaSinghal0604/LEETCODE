/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        if(head==nullptr || k==0) return head;
        ListNode *n=head;
        ListNode *tail, *nhead=head;
        int c=0;
        while(n!=nullptr){
            c++;
            tail=n;
            n=n->next;
        }
        k%=c;
        k=c-k-1;
        while(k--){
            nhead=nhead->next;
        }
        tail->next=head;
        head=nhead->next;
        nhead->next=nullptr;
        return head;
    }
};
