class Solution {
public:
    vector<vector<char>> rotateTheBox(vector<vector<char>>& boxGrid) {
        int r=boxGrid.size(), c=boxGrid[0].size();
        vector<vector<char>>res(c, vector<char>(r));
        for(int i=0; i<r; i++){
            int e=c-1;
            for(int j=c-1; j>=0; j--){
                if(boxGrid[i][j]=='*'){
                    e=j-1;
                }else if(boxGrid[i][j]=='#'){
                    swap(boxGrid[i][j],boxGrid[i][e]);
                    e--;
                }
            }
        }
        for(int i=0; i<r; i++){
            for(int j=0; j<c; j++){
                res[j][i]=boxGrid[i][j];
            }
        }
        for(int i=0; i<c; i++){
            reverse(res[i].begin(), res[i].end());
        }
        return res;
    }
};
