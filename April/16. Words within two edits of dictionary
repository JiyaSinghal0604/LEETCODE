class Solution {
public:
    vector<string> twoEditWords(vector<string>& q, vector<string>& d) {
        vector<string> res;
        for (int i = 0; i < q.size(); i++) {
            for (int j = 0; j < d.size(); j++) {
                if (q[i] == d[j]) {
                    res.push_back(q[i]);
                    break;
                } else if (q[i].size() != d[j].size())
                    continue;
                else {
                    int c = 0;
                    for (int k = 0; k < q[i].size(); k++) {
                        if (q[i][k] != d[j][k])
                            c++;
                        if (c > 2)
                            break;
                    }
                    if (c <= 2) {
                        res.push_back(q[i]);
                        break;
                    }
                }
            }
        }
        return res;
    }
};
