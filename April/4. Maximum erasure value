class Solution {
public:
    int maximumUniqueSubarray(vector<int>& nums) {
        unordered_set<int>o;
        int l=0, r=0, sum=0, ans=0;
        for(r=0; r<nums.size(); r++){
            while(o.find(nums[r])!=o.end()){
                o.erase(nums[l]);
                sum-=nums[l];
                l++;
            }
            sum+=nums[r];
            o.insert(nums[r]);
            ans=max(ans,sum);
        }
        return ans;
    }
};
