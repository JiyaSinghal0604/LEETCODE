class Solution {
public:
    int countPairs(vector<int>& nums, int target) {
        int c=0;
        for(int i=0; i<nums.size(); i++){
            int s=nums[i];
            for(int j=i+1; j<nums.size(); j++){
                if(s+nums[j]<target) c++;
            }
        }
        return c;
    }
};
