class Solution {
public:
    int numberOfBeams(vector<string>& bank) {
        int ans=0;
        int prev=0;
        for(auto x: bank[0]){
            if(x=='1') prev++;
        }
        for(int i=1; i<bank.size(); i++){
            int b=0;
            for(auto x:bank[i]){
                if(x=='1') b++;
            }
            if(b==0) continue;
            ans+=prev*b;
            prev=b;
        }
        return ans;
    }
};
