class Solution {
public:
    int maxVowels(string s, int k) {
        unordered_set<char>v={'a','e','i','o','u'};
        int c=0;
        for(int i=0; i<k; i++){
            if(v.count(s[i])) c++;
        }
        int i=k, curr=c;
        for(i; i<s.size(); i++){
            if(!v.count(s[i-k]) && v.count(s[i])) curr++;
            else if(v.count(s[i-k]) && !v.count(s[i])) curr--;
            c=max(curr,c);
        }
        return c;
    }
};
