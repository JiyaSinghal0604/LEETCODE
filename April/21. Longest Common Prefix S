class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        string com=strs[0];
        int s=com.size()-1;
        for(int i=0; i<strs.size(); i++){
            for(int j=0; j<com.size(); j++){
                if(s<j) break;
                if(com[j]!=strs[i][j]){
                    s=j-1;
                    break;
                }
            }
        }
        string res="";
        for(int i=0; i<=s; i++){
            res.push_back(com[i]);
        }
        return res;
    }
};
